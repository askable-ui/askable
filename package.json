{
  "name": "askable",
  "version": "0.15.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run build:e2e-bundle && playwright test",
    "build:e2e-bundle": "esbuild packages/core/src/index.ts --bundle --format=iife --global-name=AskableCore --outfile=e2e/.bundle/askable-core.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vue/server-renderer": "^3.5.38",
    "esbuild": "0.28.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue": "^3.5.35"
  }
}
