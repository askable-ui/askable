{
  "name": "@askable-ui/angular",
  "version": "0.15.0",
  "description": "Angular service and directive to give AI assistants real-time context about what users see and select",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./extended": {
      "import": "./dist/extended.js",
      "types": "./dist/extended.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askable-ui/askable.git",
    "directory": "packages/angular"
  },
  "scripts": {
    "prebuild": "npm run build -w @askable-ui/core",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "context",
    "claude",
    "cursor",
    "copilot",
    "angular",
    "signals",
    "agentic",
    "data-askable"
  ],
  "homepage": "https://askable-ui.com",
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0"
  },
  "dependencies": {
    "@askable-ui/core": "^0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.2",
    "@angular/build": "^22.0.4",
    "@angular/common": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-browser-dynamic": "^22.0.4",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zone.js": "^0.16.2"
  }
}
