{
  "name": "@askable-ui/core",
  "version": "0.14.0",
  "description": "Give AI assistants real-time context about what users see and select in your UI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askable-ui/askable.git",
    "directory": "packages/core"
  },
  "scripts": {
    "prebuild": "npm run build -w @askable-ui/context",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "bench": "node bench/perf.mjs",
    "bench:ci": "node bench/perf.mjs --budget"
  },
  "keywords": [
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "context",
    "claude",
    "cursor",
    "copilot",
    "agentic",
    "ui",
    "focus",
    "data-askable"
  ],
  "homepage": "https://askable-ui.com",
  "license": "MIT",
  "dependencies": {
    "@askable-ui/context": "^0.14.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
