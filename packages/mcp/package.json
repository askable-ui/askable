{
  "name": "@askable-ui/mcp",
  "version": "0.14.0",
  "description": "MCP server and page bridge to expose UI context to Claude Desktop, Cursor, and any MCP client",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askable-ui/askable.git",
    "directory": "packages/mcp"
  },
  "scripts": {
    "prebuild": "npm run build -w @askable-ui/context",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "cursor",
    "ai",
    "agent",
    "agentic",
    "context",
    "llm",
    "copilot",
    "data-askable"
  ],
  "homepage": "https://askable-ui.com",
  "license": "MIT",
  "dependencies": {
    "@askable-ui/context": "^0.14.0",
    "@askable-ui/core": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
