    "directory": "packages/tanstack-table"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": ["llm", "context", "tanstack-table", "react-table", "table", "askable"],
  "homepage": "https://askable-ui.com",
  "license": "MIT",
