{
  "name": "@askable-ui/vue",
  "version": "0.15.0",
  "description": "Vue 3 composables to give AI assistants real-time context about what users see and select",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./extended": {
      "import": "./dist/extended.js",
      "types": "./dist/extended.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askable-ui/askable.git",
    "directory": "packages/vue"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "context",
    "claude",
    "cursor",
    "copilot",
    "vue",
    "vue3",
    "composable",
    "agentic",
    "data-askable"
  ],
  "homepage": "https://askable-ui.com",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@askable-ui/core": "^0.15.0"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.35"
  }
}
